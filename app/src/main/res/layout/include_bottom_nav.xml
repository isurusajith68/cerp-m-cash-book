<?xml version="1.0" encoding="utf-8"?>
<!--
  Shared bottom-nav bar.

  Each host screen calls BottomNav.bind(...) on this layout's root and passes
  the active tab key (`home` / `alerts` / `ledger` / `settings`). The helper
  applies the green pill background + primary tint to the active tab and wires
  click listeners to start the appropriate Activity using SINGLE_TOP +
  CLEAR_TOP to avoid stacking duplicates.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/bottom_bar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_bar"
    android:elevation="12dp"
    android:orientation="horizontal"
    android:paddingHorizontal="6dp"
    android:paddingTop="18dp"
    android:paddingBottom="12dp">

    <!-- HOME -->
    <LinearLayout
        android:id="@+id/nav_home"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical">

        <FrameLayout
            android:id="@+id/pill_home"
            android:layout_width="64dp"
            android:layout_height="34dp">

            <ImageView
                android:id="@+id/icon_home"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="Home"
                android:src="@drawable/ic_nav_home"
                android:tint="@color/text_secondary" />
        </FrameLayout>

        <TextView
            android:id="@+id/label_home"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Home"
            android:textColor="@color/text_secondary"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- ALERTS -->
    <LinearLayout
        android:id="@+id/nav_notifications"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical">

        <FrameLayout
            android:id="@+id/pill_alerts"
            android:layout_width="64dp"
            android:layout_height="34dp">

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center">

                <ImageView
                    android:id="@+id/icon_alerts"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="Notifications"
                    android:src="@drawable/ic_notifications"
                    android:tint="@color/text_secondary" />

                <TextView
                    android:id="@+id/tv_notif_badge"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="-4dp"
                    android:layout_marginEnd="-6dp"
                    android:background="@drawable/bg_select_circle"
                    android:backgroundTint="@color/error"
                    android:gravity="center"
                    android:textColor="@color/white"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </FrameLayout>
        </FrameLayout>

        <TextView
            android:id="@+id/label_alerts"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Alerts"
            android:textColor="@color/text_secondary"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- LEDGER -->
    <LinearLayout
        android:id="@+id/nav_ledger"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical">

        <FrameLayout
            android:id="@+id/pill_ledger"
            android:layout_width="64dp"
            android:layout_height="34dp">

            <ImageView
                android:id="@+id/icon_ledger"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="Ledger"
                android:src="@drawable/ic_ledger"
                android:tint="@color/text_secondary" />
        </FrameLayout>

        <TextView
            android:id="@+id/label_ledger"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Ledger"
            android:textColor="@color/text_secondary"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- SETTINGS -->
    <LinearLayout
        android:id="@+id/nav_settings"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical">

        <FrameLayout
            android:id="@+id/pill_settings"
            android:layout_width="64dp"
            android:layout_height="34dp">

            <ImageView
                android:id="@+id/icon_settings"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="Settings"
                android:src="@drawable/ic_nav_settings"
                android:tint="@color/text_secondary" />
        </FrameLayout>

        <TextView
            android:id="@+id/label_settings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Settings"
            android:textColor="@color/text_secondary"
            android:textSize="11sp" />
    </LinearLayout>
</LinearLayout>
